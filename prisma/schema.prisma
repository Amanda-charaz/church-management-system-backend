generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Church {
  id      String  @id @default(uuid())
  name    String
  address String?
  users   User[]
}

model User {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  password String
  role     Role
  church   Church  @relation(fields: [churchId], references: [id])
  churchId String
}

enum Role {
  ADMIN
  PASTOR
  FINANCE
  MEMBER
}