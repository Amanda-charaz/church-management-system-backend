generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PASTOR
  FINANCE
  MEMBER
}

enum MemberStatus {
  ACTIVE
  INACTIVE
}

enum FinanceType {
  INCOME
  EXPENSE
}

model Church {
  id        String   @id @default(uuid())
  name      String
  address   String?
  createdAt DateTime @default(now())

  users        User[]
  members      Member[]
  visitors     Visitor[]
  announcements Announcement[]
  finances     Finance[]
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())

  church   Church @relation(fields: [churchId], references: [id])
  churchId String
}

model Member {
  id        String       @id @default(uuid())
  firstName String
  lastName  String
  phone     String?
  email     String?
  department String?
  status    MemberStatus @default(ACTIVE)
  createdAt DateTime     @default(now())

  church   Church @relation(fields: [churchId], references: [id])
  churchId String
}

model Visitor {
  id         String   @id @default(uuid())
  firstName  String
  lastName   String
  phone      String?
  email      String?
  visitDate  DateTime @default(now())
  followUp   Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())

  church   Church @relation(fields: [churchId], references: [id])
  churchId String
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  content   String
  createdAt DateTime @default(now())

  church   Church @relation(fields: [churchId], references: [id])
  churchId String
}

model Finance {
  id          String      @id @default(uuid())
  title       String
  amount      Float
  type        FinanceType
  description String?
  createdAt   DateTime    @default(now())

  church   Church @relation(fields: [churchId], references: [id])
  churchId String
}