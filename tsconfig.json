{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "rootDir": ".",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": false,
    "sourceMap": true,
    "declaration": false,
    "skipLibCheck": true
  },
  "include": ["src", "prisma.config.ts"],
  "exclude": ["node_modules", "dist", "src/scripts"]
}